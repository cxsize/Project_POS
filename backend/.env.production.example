# Application
NODE_ENV=production
PORT=3000

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=pos_user
DB_PASSWORD=replace-with-a-strong-db-password
DB_DATABASE=pos_db
DB_SYNC=false
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Auth - JWT (internal)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# Auth - API Key (Open API for CRM/Accounting)
OPEN_API_KEY=replace-with-a-long-random-api-key
